    "@typescript-eslint/parser": "^8.63.0",
    "@wcj/html-to-markdown-cli": "^2.1.1",
    "eslint": "^9.39.5",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
