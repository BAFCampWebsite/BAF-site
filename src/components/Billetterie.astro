---
import { getTranslations } from '../i18n/getTranslations';
import type { BilletterieMessages } from '../i18n/types';

const t = getTranslations('billetterie');
const plusItems = [
  t('privilegeMeter.plusItems.i0'),
  t('privilegeMeter.plusItems.i1'),
  t('privilegeMeter.plusItems.i2'),
  t('privilegeMeter.plusItems.i3'),
  t('privilegeMeter.plusItems.i4'),
  t('privilegeMeter.plusItems.i5'),
  t('privilegeMeter.plusItems.i6'),
  t('privilegeMeter.plusItems.i7'),
  t('privilegeMeter.plusItems.i8'),
  t('privilegeMeter.plusItems.i9'),
  t('privilegeMeter.plusItems.i10'),
];
const minusItems = [
  t('privilegeMeter.minusItems.i0'),
  t('privilegeMeter.minusItems.i1'),
  t('privilegeMeter.minusItems.i2'),
  t('privilegeMeter.minusItems.i3'),
  t('privilegeMeter.minusItems.i4'),
  t('privilegeMeter.minusItems.i5'),
  t('privilegeMeter.minusItems.i6'),
  t('privilegeMeter.minusItems.i7'),
  t('privilegeMeter.minusItems.i8'),
];
const minusAsPlus = new Set<number>([]);
const pricingTiers = [
  {
    class: 'tarif-soutien',
    letter: 'A',
    priceLabel: t('pricing.tierSupport.priceLabel'),
    totalLabel: t('pricing.tierSupport.totalLabel'),
    description: t('pricing.tierSupport.description'),
  },
  {
    class: 'tarif-reel',
    letter: 'B',
    priceLabel: t('pricing.tierCost.priceLabel'),
    totalLabel: t('pricing.tierCost.totalLabel'),
    description: t('pricing.tierCost.description'),
  },
  {
    class: 'tarif-reduit',
    letter: 'C',
    priceLabel: t('pricing.tierReduced.priceLabel'),
    totalLabel: t('pricing.tierReduced.totalLabel'),
    description: t('pricing.tierReduced.description'),
  },
];
---

<!-- Hero -->
<div class="page-hero anim">
  <p class="page-hero-eyebrow">🎟️ {t('hero.eyebrow')}</p>
  <h1 class="page-hero-title">{t('hero.title')}</h1>
  <p class="page-hero-sub">{t('hero.subtitle')}</p>
</div>

<div class="page-content">
  <!-- Section 1 — Intro -->
  <div class="reveal section-intro">
    <h2>{t('intro.title')}</h2>
    <p
      class="section-lead"
      set:html={t('intro.p1')}
    />
    <p
      class="section-lead"
      set:html={t('intro.p2')}
    />
    <p class="section-lead">{t('intro.p3')}</p>
    <p
      class="section-lead"
      set:html={t('intro.p4')}
    />
    <p class="section-lead section-footnote">
      <sup>*</sup>
      <a
        href={t('intro.footnote1Url')}
        target="_blank"
        rel="noopener"
        class="section-footnote-link"
        >{t('intro.footnote1')}</a
      >
      {t('intro.footnote1Text')}<br />
      <sup>**</sup>
      <a
        href={t('intro.footnote2Url')}
        target="_blank"
        rel="noopener"
        class="section-footnote-link"
        >{t('intro.footnote2')}</a
      >
      {t('intro.footnote2Text')}
    </p>
  </div>

  <hr class="divider" />

  <!-- Section 2 — Privilege Meter -->
  <div
    class="reveal"
    id="thunometre-section"
  >
    <h2>🌡️ {t('privilegeMeter.title')}</h2>
    <p class="section-lead">{t('privilegeMeter.description')}</p>

    <div class="thuno-tool">
      <div
        class="thuno-questions"
        id="thunoQuestions"
      >
        <p class="thuno-intro-label">📊 {t('privilegeMeter.introLabel')}</p>

        <div class="thuno-group">
          <p class="thuno-group-title">➕ {t('privilegeMeter.plusGroupTitle')}</p>
          {
            plusItems.map((item) => (
              <label class="thuno-item">
                <input
                  type="checkbox"
                  class="thuno-cb"
                  data-val="1"
                />{' '}
                {item}
              </label>
            ))
          }
        </div>

        <div class="thuno-group thuno-group-minus">
          <p class="thuno-group-title">➖ {t('privilegeMeter.minusGroupTitle')}</p>
          {
            minusItems.map((item, i) => (
              <label class="thuno-item">
                <input
                  type="checkbox"
                  class="thuno-cb"
                  data-val={minusAsPlus.has(i) ? 1 : -1}
                />{' '}
                {item}
              </label>
            ))
          }
        </div>

        <button
          class="btn btn-primary thuno-calc-btn"
          onclick="calculerThuno()"
          >{t('privilegeMeter.btnCalculate')}</button
        >
      </div>

      <div
        class="thuno-result"
        id="thunoResult"
        style="display:none;"
      >
        <div class="thuno-tier-wrap">
          <div
            class="thuno-tier thuno-tier-high"
            id="thunoTierHigh"
          >
            💰 {t('privilegeMeter.tierHigh')}
          </div>
          <div
            class="thuno-tier thuno-tier-mid"
            id="thunoTierMid"
          >
            ⚖️ {t('privilegeMeter.tierMid')}
          </div>
          <div
            class="thuno-tier thuno-tier-low"
            id="thunoTierLow"
          >
            🌱 {t('privilegeMeter.tierLow')}
          </div>
        </div>
        <div class="thuno-score-block">
          <span class="thuno-score-label">{t('privilegeMeter.scoreLabel')}</span>
          <span
            class="thuno-score-value"
            id="thunoScoreVal"
            >0</span
          >
        </div>
        <div
          class="thuno-reco"
          id="thunoReco"
          data-reco-high={`🌟 <strong>${t('privilegeMeter.recoHigh.title')}</strong> ${t('privilegeMeter.recoHigh.description')}`}
          data-reco-mid={`⚖️ <strong>${t('privilegeMeter.recoMid.title')}</strong> ${t('privilegeMeter.recoMid.description')}`}
          data-reco-low={`💚 <strong>${t('privilegeMeter.recoLow.title')}</strong> ${t('privilegeMeter.recoLow.description')}`}
        >
        </div>
        <button
          class="btn thuno-reset-btn"
          onclick="resetThuno()"
          >{t('privilegeMeter.btnReset')}</button
        >
      </div>
    </div>
  </div>

  <hr class="divider" />

  <!-- Section 3 — Pricing -->
  <div class="reveal">
    <h2>{t('pricing.title')}</h2>

    <div class="tarif-scale">
      {
        pricingTiers.map((tier) => (
          <div class={`tarif-band ${tier.class}`}>
            <span class="tarif-letter">{tier.letter}</span>
            <div>
              <strong>
                {tier.priceLabel} <span class="tarif-total">— {tier.totalLabel}</span>
              </strong>
              <p>{tier.description}</p>
            </div>
          </div>
        ))
      }
    </div>

    <p
      class="thuno-formula-note"
      set:html={t('privilegeMeter.formulaNote')}
    />

    <div class="tarif-camping-block">
      <span class="tarif-camping-icon">⛺</span>
      <div>
        <strong>{t('pricing.campingTitle')}</strong>
        <p set:html={t('pricing.campingText')} />
      </div>
    </div>
  </div>

  <hr class="divider" />

  <!-- Section 4 — Registration -->
  <div
    class="reveal"
    id="inscription"
  >
    <h2>🎟️ {t('registration.title')}</h2>
    <p class="section-lead">{t('registration.description')}</p>

    <div class="step-block">
      <div class="step-num">{t('registration.stepNum')}</div>
      <div class="step-body">
        <h3>{t('registration.stepTitle')}</h3>
        <p>{t('registration.stepText')}</p>
        <a
          href={t('registration.formUrl')}
          class="btn btn-primary"
          onclick="showFormPopup(event)"
        >
          📝 {t('registration.btnForm')}
        </a>
      </div>
    </div>
  </div>

  <hr class="divider" />

  <!-- Section 5 — Contact -->
  <div class="reveal">
    <h2>{t('contact.title')}</h2>
    <p class="contact-copy">
      {t('contact.text')}
    </p>
    <a
      href={`mailto:activismcampbelgium@proton.me?subject=${encodeURIComponent(t('contact.emailSubject'))}`}
      class="btn btn-primary contact-btn"
    >
      ✉ {t('contact.btnText')}
    </a>
  </div>
</div>

<!-- Popup -->
<div
  class="popup-overlay"
  id="formPopupOverlay"
>
  <div class="popup-box">
    <button
      class="popup-close"
      onclick="closeFormPopup()"
      aria-label="Close"
      >✕</button
    >
    <p class="popup-icon">⏳</p>
    <h3>{t('popup.title')}</h3>
    <p>{t('popup.text')}</p>
    <button
      class="btn btn-primary popup-confirm-btn"
      onclick="closeFormPopup()"
      >{t('popup.btnText')}</button
    >
  </div>
</div>

<style is:global>
  /* ── Intro sections ── */
  .section-intro {
    max-width: 720px;
  }
  .section-lead {
    font-family: var(--font-serif);
    font-size: 0.97rem;
    line-height: 1.85;
    color: var(--encre);
    margin-bottom: 14px;
    max-width: 720px;
  }

  /* ── Thunomètre / Privilègomètre ── */
  .thuno-tool {
    background: var(--blanc-sale);
    border: var(--contour-lg);
    border-radius: 16px;
    padding: 32px 28px;
    box-shadow: var(--ombre-lg);
    max-width: 760px;
    margin-top: 24px;
  }

  .thuno-intro-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--rose);
    margin-bottom: 20px;
  }

  .thuno-group {
    margin-bottom: 28px;
  }

  .thuno-group-title {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--encre);
    margin-bottom: 12px;
    padding: 6px 12px;
    background: var(--creme-fonce);
    border-radius: 6px;
    display: inline-block;
  }

  .thuno-group-minus .thuno-group-title {
    background: #fde8e8;
    color: #c0392b;
  }

  .thuno-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--font-serif);
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--encre);
    padding: 8px 10px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
    margin-bottom: 4px;
  }

  .thuno-item:hover {
    background: var(--creme);
  }

  .thuno-cb {
    margin-top: 3px;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    accent-color: var(--rose);
  }

  /* Result */
  .thuno-result {
    text-align: center;
  }

  .thuno-tier-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
  }

  .thuno-tier {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 10px 20px;
    border-radius: 40px;
    border: 2px solid transparent;
    opacity: 0.35;
    transition: all 0.3s;
    letter-spacing: 0.04em;
  }

  .thuno-tier.active {
    opacity: 1;
    transform: scale(1.05);
  }

  .thuno-tier-high.active {
    background: #e8f5e9;
    border-color: #2e7d32;
    color: #2e7d32;
  }
  .thuno-tier-mid.active {
    background: #fef3e2;
    border-color: #c0820b;
    color: #c0820b;
  }
  .thuno-tier-low.active {
    background: #ede9f6;
    border-color: #6b5fa5;
    color: #6b5fa5;
  }

  .thuno-score-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin-bottom: 20px;
  }

  .thuno-score-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--sable);
    text-transform: uppercase;
  }

  .thuno-score-value {
    font-family: var(--font-mono);
    font-size: 3rem;
    font-weight: 700;
    color: var(--rose);
    line-height: 1;
  }

  .thuno-reco {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--encre);
    background: var(--creme);
    border-radius: 10px;
    padding: 16px 20px;
    max-width: 480px;
    margin: 0 auto;
  }

  .thuno-formula-note {
    font-family: var(--font-serif);
    font-size: 0.82rem;
    font-style: italic;
    color: var(--sable);
    margin-top: 10px;
    max-width: 660px;
    line-height: 1.7;
  }

  /* ── Tarifs ── */
  .tarif-scale {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 720px;
    margin-top: 20px;
  }

  .tarif-band {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 18px 22px;
    border-radius: 12px;
    border-left: 5px solid transparent;
  }

  .tarif-band h4,
  .tarif-band strong {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 700;
    display: block;
    margin-bottom: 2px;
  }

  .tarif-band p {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--encre);
    margin: 4px 0 0;
    line-height: 1.6;
  }

  .tarif-total {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-weight: 400;
    font-style: italic;
    opacity: 0.75;
  }

  .tarif-letter {
    font-family: var(--font-mono);
    font-size: 1.3rem;
    font-weight: 700;
    min-width: 48px;
    flex-shrink: 0;
    color: inherit;
    opacity: 0.6;
  }

  .tarif-soutien {
    background: #f1f8e9;
    border-color: #558b2f;
    color: #558b2f;
  }
  .tarif-reel {
    background: var(--creme);
    border-color: var(--sable);
    color: var(--encre);
  }
  .tarif-reduit {
    background: #ede9f6;
    border-color: #6b5fa5;
    color: #6b5fa5;
  }

  /* ── Tarif camping ── */
  .tarif-camping-block {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-top: 20px;
    max-width: 720px;
    background: #f0f4ff;
    border: 2px dashed #7b9de0;
    border-radius: 12px;
    padding: 18px 22px;
  }

  .tarif-camping-icon {
    font-size: 1.8rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .tarif-camping-block strong {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 700;
    color: #3a5a9a;
    display: block;
    margin-bottom: 4px;
  }

  .tarif-camping-block p {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--encre);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Étapes inscription ── */
  .step-block {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    margin-bottom: 40px;
    max-width: 760px;
  }

  .step-num {
    font-family: var(--font-mono);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--rose);
    background: var(--creme-fonce);
    border: 2px solid var(--rose);
    border-radius: 50%;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .step-body h3 {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--encre);
    margin-bottom: 12px;
  }

  .step-body p {
    font-family: var(--font-serif);
    font-size: 0.92rem;
    line-height: 1.8;
    color: var(--encre);
    margin-bottom: 10px;
    max-width: 640px;
  }

  /* ── Popup formulaire ── */
  .popup-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(20, 15, 10, 0.55);
    z-index: 999;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .popup-box {
    background: var(--blanc-sale);
    border: var(--contour-lg);
    border-radius: 16px;
    box-shadow: var(--ombre-lg);
    padding: 36px 30px;
    max-width: 380px;
    width: 100%;
    text-align: center;
    position: relative;
    animation: popupIn 0.25s ease;
  }

  @keyframes popupIn {
    from {
      transform: scale(0.92);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .popup-icon {
    font-size: 2.4rem;
    margin: 0 0 10px;
  }

  .popup-box h3 {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--encre);
    margin-bottom: 12px;
  }

  .popup-box p {
    font-family: var(--font-serif);
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--encre);
    margin: 0;
  }

  .popup-close {
    position: absolute;
    top: 12px;
    right: 14px;
    background: none;
    border: none;
    font-size: 1.1rem;
    cursor: pointer;
    color: var(--sable);
    padding: 4px 8px;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .popup-close:hover {
    background: var(--creme-fonce);
  }

  /* ══ RESPONSIVE MOBILE ══ */
  @media (max-width: 600px) {
    .thuno-tool {
      padding: 20px 16px;
    }
    .thuno-item {
      font-size: 0.83rem;
      padding: 7px 6px;
    }
    .tarif-band {
      flex-direction: column;
      gap: 6px;
    }
    .tarif-camping-block {
      flex-direction: column;
      gap: 8px;
    }
    .step-block {
      flex-direction: column;
      gap: 14px;
    }
    .step-num {
      width: 40px;
      height: 40px;
      font-size: 1.3rem;
    }
    .popup-box {
      padding: 28px 20px;
    }
  }
</style>

<script>
  window.calculerThuno = function () {
    const checkboxes = document.querySelectorAll('.thuno-cb');
    let score = 0;
    checkboxes.forEach((cb) => {
      if (cb.checked) score += parseInt(cb.dataset.val);
    });

    document.getElementById('thunoScoreVal').textContent = score > 0 ? '+' + score : score;
    document.getElementById('thunoQuestions').style.display = 'none';
    document.getElementById('thunoResult').style.display = 'block';

    const high = document.getElementById('thunoTierHigh');
    const mid = document.getElementById('thunoTierMid');
    const low = document.getElementById('thunoTierLow');
    [high, mid, low].forEach((el) => el.classList.remove('active'));

    const reco = document.getElementById('thunoReco');

    if (score >= 8) {
      high.classList.add('active');
      reco.innerHTML = reco.dataset.recoHigh;
    } else if (score >= 4) {
      mid.classList.add('active');
      reco.innerHTML = reco.dataset.recoMid;
    } else {
      low.classList.add('active');
      reco.innerHTML = reco.dataset.recoLow;
    }
  };

  window.resetThuno = function () {
    document.querySelectorAll('.thuno-cb').forEach((cb) => (cb.checked = false));
    document.getElementById('thunoResult').style.display = 'none';
    document.getElementById('thunoQuestions').style.display = 'block';
  };

  window.showFormPopup = function (e) {
    e.preventDefault();
    document.getElementById('formPopupOverlay').style.display = 'flex';
  };

  window.closeFormPopup = function () {
    document.getElementById('formPopupOverlay').style.display = 'none';
  };

  document.getElementById('formPopupOverlay').addEventListener('click', function (e) {
    if (e.target === this) window.closeFormPopup();
  });
</script>
