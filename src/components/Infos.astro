---
import { getLocale } from 'astro-intl';
import { getTranslations } from '../i18n/getTranslations';

const lang = getLocale();
const p = `/${lang}`;
const t = getTranslations('infos');

const accesCards = [
  {
    icon: '🚆',
    title: t('acces.train.title'),
    text: t('acces.train.text'),
    linkLabel: t('acces.train.linkLabel'),
    linkUrl: t('acces.train.linkUrl'),
    warningLabel: t('acces.train.warningLabel'),
    warningText: t('acces.train.warningText'),
  },
  { icon: '🚲', title: t('acces.velo.title'), text: t('acces.velo.text') },
  { icon: '🚗', title: t('acces.voiture.title'), text: t('acces.voiture.text') },
];

const bambinerieBlocks = [
  { icon: '🌅', title: t('bambinerie.morning.title'), html: t('bambinerie.morning.html') },
  { icon: '🌤️', title: t('bambinerie.afternoon.title'), html: t('bambinerie.afternoon.html') },
  { icon: '🎨', title: t('bambinerie.activities.title'), html: t('bambinerie.activities.html') },
  { icon: '💬', title: t('bambinerie.contact.title'), prefix: t('bambinerie.contact.prefix'), suffix: t('bambinerie.contact.suffix') },
];
---

<div class="page-hero anim">
  <p class="page-hero-eyebrow">{t('hero.eyebrow')}</p>
  <h1 class="page-hero-title">{t('hero.title')}</h1>
  <p class="page-hero-sub">{t('hero.subtitle')}</p>
</div>

<div class="page-content">

  <div class="reveal reveal-spacing">
    <div class="construction-banner">
      🚧 {t('construction')}
    </div>
  </div>

  <section id="acces">
    <p class="section-label">📍 {t('acces.sectionLabel')}</p>
    <h2>{t('acces.title')}</h2>

    <div class="info-grid">
      {accesCards.map((card) => (
        <div>
          <div class="info-card surface-card">
            <span class="info-card-icon">{card.icon}</span>
            <h3 class="info-card-title">{card.title}</h3>
            <p>{card.text}</p>
            {card.linkLabel && card.linkUrl && (
              <a class="info-card-link" href={card.linkUrl} target="_blank" rel="noopener noreferrer">
                {card.linkLabel}
              </a>
            )}
          </div>
          {card.warningText && (
            <div class="info-card-warning">
              <strong>{card.warningLabel}</strong>
              <p>{card.warningText}</p>
            </div>
          )}
        </div>
      ))}

      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
      <div id="map" class="map-panel"></div>
    </div>
  </section>

  <hr class="divider">

  <section id="restauration" class="section-contrast">
    <div class="page-content">
      <div class="section-alt">
        <p class="section-label">🍴 {t('restauration.sectionLabel')}</p>
        <h2 class="section-contrast-title">{t('restauration.title')}</h2>
        <p class="section-contrast-content" set:html={t('restauration.html')}></p>
      </div>
    </div>
  </section>

  <section id="camping">
    <p class="section-label">⛺ {t('camping.sectionLabel')}</p>
    <h2>{t('camping.title')}</h2>
    <p set:html={t('camping.html')}></p>
    <p>{t('camping.mixiteText')}</p>

    <div class="info-block">
      <span class="info-block-icon">🗓️</span>
      <div class="info-block-body">
        <div class="info-block-title">{t('camping.dates.title')}</div>
        <p>{t('camping.dates.text')}</p>
      </div>
    </div>
  </section>

  <hr class="divider">

  <section id="bambinerie">
    <p class="section-label">🧒 {t('bambinerie.sectionLabel')}</p>
    <h2>{t('bambinerie.title')}</h2>
    <p style="font-family:var(--font-serif); font-size:.93rem; line-height:1.8;" set:html={t('bambinerie.introHtml')}></p>

    {bambinerieBlocks.map((block) => (
      <div class="info-block surface-card">
        <span class="info-block-icon">{block.icon}</span>
        <div class="info-block-body">
          <div class="info-block-title">{block.title}</div>
          {block.html ? (
            <p set:html={block.html}></p>
          ) : (
            <p>{block.prefix}<a href="mailto:activismcampbelgium@proton.me" class="text-link-accent">activismcampbelgium@proton.me</a>{block.suffix}</p>
          )}
        </div>
      </div>
    ))}
  </section>

</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  const map = L.map('map', { scrollWheelZoom: false }).setView([49.9072, 5.2697], 15);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors',
    maxZoom: 19
  }).addTo(map);
  L.marker([50.0923867580313, 5.277445980713076])
    .addTo(map)
    .bindPopup('<strong>BAF Camp</strong><br>1 chemin de Lavaux<br>6927 Tellin, Belgique')
    .openPopup();
</script>

<style is:global>
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-bottom: 48px;
  }
  .info-card {
    background: var(--blanc-sale);
    border: var(--contour-lg);
    border-radius: 12px;
    padding: 28px 24px;
    box-shadow: var(--ombre-lg);
    transition: transform .15s;
    position: relative; overflow: hidden;
  }
  .info-card::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 5px;
    background: var(--rose);
    border-radius: 12px 12px 0 0;
  }
  .info-card:nth-child(2n)::after { background: var(--vert); }
  .info-card:hover { transform: translate(-3px, -3px); }
  .info-card-icon { font-size: 2rem; margin-bottom: 12px; display: block; }
  .info-card-title {
    font-family: var(--font-display);
    font-size: 1.3rem; letter-spacing: .04em;
    color: var(--vert);
    margin-bottom: 10px;
    text-shadow: 1px 1px 0 var(--encre), -1px -1px 0 var(--encre), 1px -1px 0 var(--encre), -1px 1px 0 var(--encre);
  }
  .info-card p {
    font-family: var(--font-serif);
    font-size: .84rem; line-height: 1.7; color: var(--gris-encre);
    margin-bottom: 0;
  }
  .info-card-link {
    display: inline-block;
    margin-top: 10px;
    font-family: var(--font-mono);
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--rose);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .info-card-warning {
    margin-top: 10px;
    padding: 12px 14px;
    border: 2px solid #c62828;
    border-radius: 10px;
    background: #ffe2e2;
    box-shadow: 4px 4px 0 #c62828;
  }
  .info-card-warning strong {
    display: block;
    margin-bottom: 4px;
    font-family: var(--font-display);
    font-size: .95rem;
    color: #8e1d1d;
  }
  .info-card-warning p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: .82rem;
    line-height: 1.6;
    color: #8e1d1d;
  }

  .section-alt {
    background: var(--rose);
    margin: 0 -80px;
    padding: 48px 80px;
    border-top: 3px solid var(--encre);
    border-bottom: 3px solid var(--encre);
    position: relative; overflow: hidden;
  }
  .section-alt::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.08) 1px, transparent 1px);
    background-size: 14px 14px; pointer-events: none;
  }
  .section-alt h2 {
    color: var(--creme) !important;
    text-shadow: 2px 2px 0 var(--encre), -1px -1px 0 var(--encre), 1px -1px 0 var(--encre), -1px 1px 0 var(--encre) !important;
  }
  .section-alt .info-card-title { color: var(--rose); }
  .section-alt .info-card::after { background: var(--vert); }
  .section-alt .info-card:nth-child(2n)::after { background: var(--rose-dark); }

  .info-block {
    display: flex; gap: 20px; align-items: flex-start;
    padding: 20px;
    background: var(--blanc-sale);
    border: var(--contour);
    border-radius: 10px;
    box-shadow: var(--ombre);
    margin-bottom: 16px;
    transition: transform .15s;
  }
  .info-block:hover { transform: translate(-2px, -2px); }
  .info-block-icon { font-size: 1.8rem; flex-shrink: 0; line-height: 1; }
  .info-block-body {}
  .info-block-title {
    font-family: var(--font-display);
    font-size: 1.1rem; color: var(--vert); margin-bottom: 6px;
    text-shadow: 1px 1px 0 var(--encre), -1px -1px 0 var(--encre), 1px -1px 0 var(--encre), -1px 1px 0 var(--encre);
  }
  .info-block p {
    font-family: var(--font-serif);
    font-size: .84rem; line-height: 1.7; color: var(--gris-encre); margin-bottom: 0;
  }

  .section-label {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-mono);
    font-size: .65rem; font-weight: 700; letter-spacing: .22em; text-transform: uppercase;
    background: var(--vert); color: var(--creme);
    padding: 4px 12px; border-radius: 4px;
    border: 1px solid var(--encre); box-shadow: 2px 2px 0 var(--encre);
    margin-bottom: 14px;
  }

  @media(max-width: 900px) {
    .section-alt { margin: 0 -20px; padding: 40px 20px; }
  }
</style>
