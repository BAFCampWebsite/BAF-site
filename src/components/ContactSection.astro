---
import { getTranslations } from '../i18n/getTranslations';

const t = getTranslations('contact');
---

<section class="section-contact" id="contact">
  <div class="section-contact-shell">
    <p class="section-eyebrow reveal section-contact-eyebrow">{t('eyebrow')}</p>
    <h2 class="section-title reveal section-contact-title">{t('title')}</h2>
    <p class="contact-sub reveal">{t('text')}</p>
    <a href="mailto:activismcampbelgium@proton.me" class="btn btn-primary reveal section-contact-cta">✉ {t('btnText')}</a>
  </div>
</section>
