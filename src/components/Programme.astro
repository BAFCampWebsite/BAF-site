---
import { getLocale } from "astro-intl";
import { getTranslations } from "../i18n/getTranslations";

const lang = getLocale();
const t = getTranslations("programme");

const dayTabs = [
  t("dayTabs.i0"),
  t("dayTabs.i1"),
  t("dayTabs.i2"),
  t("dayTabs.i3"),
];
const dayContent = [
  t("dayContent.i0"),
  t("dayContent.i1"),
  t("dayContent.i2"),
  t("dayContent.i3"),
];

const spaceItems = [
  { 
    icon: "🔥",
    title: t("spaces.items.i0.title"),
    text: t("spaces.items.i0.text") 
  },
  { 
    icon: "❤️",
    title: t("spaces.items.i1.title"),
    text: t("spaces.items.i1.text") 
  },
  { 
    icon: "📚",
    title: t("spaces.items.i2.title"),
    text: t("spaces.items.i2.text") 
  },
  { 
    icon: "🌊",
    title: t("spaces.items.i3.title"),
    text: t("spaces.items.i3.text") 
  },
];
---

<div class="page-hero anim">
  <p class="page-hero-eyebrow">✦ {t("hero.eyebrow")}</p>
  <h1 class="page-hero-title">{t("hero.title")}</h1>
  <p class="page-hero-sub">{t("hero.subtitle")}</p>
</div>

<div class="page-content">
  <div class="reveal reveal-spacing">
    <div class="construction-banner">
      🚧 {t("construction")}
    </div>
  </div>

  <div class="reveal">
    <h2>{t("intro.title")}</h2>
    <p>{t("intro.sentence")}</p>
    <p>
      <strong>"{t("intro.together.title")}"</strong> : {
        t("intro.together.tagline")
      }
    </p>
    <p>{t("intro.together.explanation")}</p>
    <p>
      <strong>"{t("intro.struggle.title")}"</strong> : {
        t("intro.struggle.tagline")
      }
    </p>
    <p>{t("intro.struggle.explanation")}</p>
  </div>

  <div class="reveal centre">
    <svg class="titre-fil" viewBox="0 0 600 120">
      <path
        id="filPath"
        d="M10,60 Q150,10 300,60 T590,60"
        fill="none"
        stroke="none"></path>
      <text class="fil-texte">
        <textPath href="#filPath" startOffset="50%" text-anchor="middle"
          >{t("filRouge.title")}</textPath
        >
      </text>
    </svg>
    <div class="bloc-fil">{t("filRouge.text")}</div>
  </div>

  <div class="reveal reveal-spacing-large">
    <div class="day-tabs" id="dayTabs">
      {
        dayTabs.map((tab, i) => (
          <button class="day-tab" data-day={i} onclick={`switchDay(${i},this)`}>
            {tab}
          </button>
        ))
      }
    </div>
    <div id="dayContent"></div>
  </div>

  <hr class="divider" />

  <div class="reveal">
    <h2>{t("spaces.title")}</h2>
    <div class="cards-grid">
      {
        spaceItems.map((item) => (
          <div class="card">
            <span class="card-icon">
              {item.icon}
            </span>
            <h3 class="card-title">{item.title}</h3>
            <p class="card-text">{item.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style is:global>
  .centre {
    text-align: center;
  }
  .titre-fil {
    display: block;
    margin: 0 auto;
    max-width: 500px;
    width: 100%;
  }
  .fil-texte {
    fill: none;
    stroke: #c40000;
    stroke-width: 1.2;
    font-size: 20px;
    font-family: cursive;
    letter-spacing: 1px;
  }
  .bloc-fil {
    margin: 20px auto;
    padding: 20px;
    max-width: 500px;
    text-align: center;
    border: 2px dashed #c40000;
    border-radius: 20px;
    font-size: 16px;
  }
  .day-tab {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: var(--blanc-sale);
    color: var(--encre);
    border: var(--contour);
    border-radius: 20px;
    padding: 8px 18px;
    cursor: pointer;
    box-shadow: var(--ombre);
    transition:
      transform 0.12s,
      box-shadow 0.12s,
      background 0.12s,
      color 0.12s;
  }
  .day-tab:hover:not(.active) {
    background: var(--creme-fonce);
    transform: translate(-2px, -2px);
    box-shadow: var(--ombre-lg);
  }
  .day-tab:active {
    transform: translate(0, 0);
    box-shadow: none;
  }
  .day-tab.active {
    background: var(--blanc-sale);
    color: var(--rose) !important;
    border-color: var(--rose);
    box-shadow: var(--ombre-rose);
  }
  .day-editor {
    background: var(--blanc-sale);
    border: var(--contour-lg);
    border-radius: 12px;
    padding: 32px;
    box-shadow: var(--ombre-lg);
    min-height: 280px;
  }
  .day-editor-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gris-encre);
    margin-bottom: 12px;
    display: block;
  }
  .day-editor p {
    font-family: var(--font-serif);
    font-size: 0.92rem;
    line-height: 1.8;
    color: var(--encre);
  }
</style>

<script define:vars={{ dayTabs, dayContent }}>
  function switchDay(i, btn) {
    document
      .querySelectorAll(".day-tab")
      .forEach((t) => t.classList.remove("active"));
    btn.classList.add("active");
    renderDay(i);
  }

  function renderDay(i) {
    document.getElementById("dayContent").innerHTML = `
      <div class="day-editor">
        <span class="day-editor-label">${dayTabs[i]}</span>
        <p>${dayContent[i]}</p>
      </div>
    `;
  }

  document.querySelector(".day-tab")?.classList.add("active");
  renderDay(0);
</script>
