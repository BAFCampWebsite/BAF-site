---
import { getLocale } from 'astro-intl';
import { getTranslations } from '../i18n/getTranslations';

const lang = getLocale();
const p = `/${lang}`;
const t = getTranslations('nousAider');

const rejoindreCards = [ t.raw('rejoindre.cards.i0'), t.raw('rejoindre.cards.i1'), t.raw('rejoindre.cards.i2') ];
const partagerCards = [ t.raw('partager.cards.i0'), t.raw('partager.cards.i1'), t.raw('partager.cards.i2') ];
---

<div class="page-hero anim">
  <p class="page-hero-eyebrow">✦ {t('hero.eyebrow')}</p>
  <h1 class="page-hero-title">{t('hero.title')}</h1>
  <p class="page-hero-sub">{t('hero.subtitle')}</p>
</div>

<div class="page-content">

  <div class="reveal" id="rejoindre">
    <h2>{t('rejoindre.title')}</h2>
    <p set:html={t('rejoindre.text')}></p>

    <div class="cards-grid">
      {rejoindreCards.map((card) => (
        <div class="card">
          <span class="card-icon">{['🤩', '⚒️', '👋'][rejoindreCards.indexOf(card)]}</span>
          <h3 class="card-title">{card.title}</h3>
          <p class="card-text">{card.text}</p>
          <a href={`${p}/autogestion`} class="btn btn-red" style="display:inline-block;padding:15px 40px;font-size:1.2em;">
            {card.btnText}
          </a>
        </div>
      ))}
    </div>
  </div>

  <hr class="divider">

  <div id="don" class="reveal">
    <h2>{t('don.title')}</h2>
    <p class="section-lead" style="font-size:1.1em;line-height:1.6;margin-bottom:30px;" set:html={t('don.text')}></p>

    <div class="paiement-options">
      <div class="paiement-card">
        <span class="paiement-icon">🏦</span>
        <h4>{t('don.bankTransfer.title')}</h4>
        <p>{t('don.bankTransfer.text')}</p>
        <div class="iban-block">
          <code id="ibanCode"><strong>BE65 5230 8110 3896</strong></code>
          <button class="copy-btn" onclick="copyIban()" title="Copy IBAN">📋</button>
        </div>
        <p class="paiement-note" set:html={t('don.bankTransfer.note')}></p>
      </div>

      <div class="paiement-card">
        <span class="paiement-icon">📱</span>
        <h4>{t('don.qrCode.title')}</h4>
        <p>{t('don.qrCode.text')}</p>
        <div class="qr-wrap">
          <img src="/public/QR_CODE_BAF_Camp.png" alt="QR code virement BAF Camp" class="qr-img">
        </div>
        <p class="paiement-note" set:html={t('don.qrCode.note')}></p>
      </div>
    </div>
  </div>

  <hr class="divider">

  <div class="reveal" id="partager">
    <h2>{t('partager.title')}</h2>
    <p>{t('partager.text')}</p>

    <div class="cards-grid">
      {partagerCards.map((card) => (
        <div class="card">
          <span class="card-icon">{['📄', '📄', '🏷️'][partagerCards.indexOf(card)]}</span>
          <h3 class="card-title">{card.title}</h3>
          <p class="card-text">{card.text}</p>
          <p style="font-size:0.9em;color:#888;font-style:italic;">{card.note}</p>
        </div>
      ))}
    </div>
  </div>

  <hr class="divider">

  <div class="reveal" id="materiel">
    <h2>{t('materiel.title')}</h2>
    <p>{t('materiel.text')}</p>

    <div style="background:var(--blanc-sale);padding:30px;border-radius:8px;text-align:center;margin-top:20px;border:var(--contour);">
      <p style="color:var(--encre);">{t('materiel.contactText')}</p>
      <a href={`mailto:${t('materiel.email')}?subject=${encodeURIComponent(t('materiel.subject'))}`} class="btn btn-red" style="display:inline-block;margin-bottom:20px;">
        ✉️ &nbsp;{t('materiel.email')}
      </a>
      <p style="background:var(--creme-fonce);color:var(--rose-dark);padding:15px;border-radius:5px;display:inline-block;font-weight:bold;border:2px dashed var(--rose);" set:html={t('materiel.subjectWarning')}></p>
    </div>
  </div>

</div>

<style is:global>
  .section-lead { font-family: var(--font-serif); font-size: .97rem; line-height: 1.85; color: var(--encre); margin-bottom: 14px; max-width: 720px; }
  .paiement-options { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 16px; margin-bottom: 20px; max-width: 560px; }
  .paiement-card { background: var(--blanc-sale); border: var(--contour); border-radius: 14px; padding: 22px 18px; transition: box-shadow .2s, transform .2s; }
  .paiement-card:hover { box-shadow: var(--ombre-lg); transform: translateY(-2px); }
  .paiement-icon { font-size: 2rem; display: block; margin-bottom: 10px; }
  .paiement-card h4 { font-family: var(--font-mono); font-size: .88rem; font-weight: 700; color: var(--encre); margin-bottom: 8px; }
  .paiement-card p { font-family: var(--font-serif); font-size: .85rem; line-height: 1.6; color: var(--encre); margin-bottom: 8px; }
  .paiement-note { font-size: .78rem !important; color: var(--sable) !important; font-style: italic; }
  .iban-block { display: flex; align-items: center; gap: 8px; background: var(--creme); border: var(--contour); border-radius: 8px; padding: 10px 14px; margin: 10px 0; flex-wrap: wrap; }
  .iban-block code { font-family: var(--font-mono); font-size: .82rem; color: var(--encre); flex: 1; word-break: break-all; }
  .copy-btn { background: none; border: none; cursor: pointer; font-size: 1.1rem; padding: 2px 6px; border-radius: 6px; transition: background .15s; flex-shrink: 0; }
  .copy-btn:hover { background: var(--creme-fonce); }
  .qr-wrap { display: flex; justify-content: center; margin: 12px 0; }
  .qr-img { width: 160px; height: 100%; border-radius: 12px; border: 3px solid var(--rose); object-fit: contain; background: #fff; }
  @media (max-width: 600px) { .paiement-options { grid-template-columns: 1fr; } .iban-block { flex-direction: column; align-items: flex-start; } .qr-img { width: 140px; height: 140px; } }
</style>

<script>
  function copyIban() {
    const iban = 'BE65 5230 8110 3896';
    navigator.clipboard.writeText(iban).then(() => {
      const btn = document.querySelector('.copy-btn');
      if (btn) { btn.textContent = '✅'; setTimeout(() => btn.textContent = '📋', 2000); }
    });
  }
</script>
