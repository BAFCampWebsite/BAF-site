---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import EnBref from '../../components/EnBref.astro';
import ContactSection from '../../components/ContactSection.astro';
import { pagePaths } from '../../lib/pages';

export async function getStaticPaths() {
  return pagePaths('');
}

const { lang, t, slug } = Astro.props;
---

<BaseLayout {lang} {slug} title={t.site.title} description={t.site.description} keywords={t.site.keywords} locale={t.site.locale} navT={t.nav} footerT={t.footer}>
  <Hero lang={lang} t={t.hero} />
  <EnBref lang={lang} t={t.enBref} />
  <ContactSection t={t.contact} />
</BaseLayout>
